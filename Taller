        int aprobados = 0;

        Console.WriteLine("Notas de los estudiantes:");
        for (int i = 0; i < notas.Length; i++)
        {
            string estado = notas[i] >= 3.0 ? "Aprobado ✔️" : "Reprobado ✘";
            Console.WriteLine($"  Estudiante {i + 1}: {notas[i]} → {estado}");
            if (notas[i] >= 3.0) aprobados++;
        }

        double porcentaje = (double)aprobados / notas.Length * 100;
        Console.WriteLine($"\nTotal estudiantes : {notas.Length}");
        Console.WriteLine($"Aprobados         : {aprobados}");
        Console.WriteLine($"Porcentaje        : {porcentaje:F1}%");
    }

