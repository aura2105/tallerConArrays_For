    // ── EJERCICIO 9 ──────────────────────────────────────────────────────────
    static void Ejercicio09()
    {
        Console.WriteLine("=== 9. Inversión de Arreglo ===\n");

        char[] original = { 'H', 'o', 'l', 'a', 'M', 'u', 'n', 'd', 'o' };
        char[] invertido = new char[original.Length];

        Console.Write("Arreglo original: ");
        foreach (char c in original) Console.Write(c + " ");
        Console.WriteLine();

        for (int i = 0; i < original.Length; i++)
            invertido[i] = original[original.Length - 1 - i];

        Console.Write("Arreglo invertido: ");
        foreach (char c in invertido) Console.Write(c + " ");
        Console.WriteLine();
    }

    // ── EJERCICIO 10 ─────────────────────────────────────────────────────────
    static void Ejercicio10()
