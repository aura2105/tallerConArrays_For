    // ── EJERCICIO 13 ─────────────────────────────────────────────────────────
    static void Ejercicio13()
    {
        Console.WriteLine("=== 13. Comparación de Arreglos (Intersección) ===\n");

        int[] arreglo1 = { 1, 5, 9, 3, 7, 11, 15 };
