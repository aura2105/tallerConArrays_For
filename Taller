        Console.WriteLine();
        Console.Write("Arreglo 2: ");
        foreach (int n in arreglo2) Console.Write($"{n} ");
        Console.WriteLine();

        Console.Write("\nElementos en común: ");
        bool hayComunes = false;
        for (int i = 0; i < arreglo1.Length; i++)
            for (int j = 0; j < arreglo2.Length; j++)
                if (arreglo1[i] == arreglo2[j])
                {
                    Console.Write($"{arreglo1[i]} ");
                    hayComunes = true;
                }

        if (!hayComunes) Console.Write("Ninguno");
        Console.WriteLine();
    }

    // ── EJERCICIO 14 ─────────────────────────────────────────────────────────
    static void Ejercicio14()
    {
        Console.WriteLine("=== 14. Identificación de Duplicados ===\n");

        int[] numeros = { 3, 7, 2, 9, 7, 5, 3, 11, 2, 8 };

        Console.Write("Arreglo: ");
        foreach (int n in numeros) Console.Write($"{n} ");
        Console.WriteLine("\n");

        bool hayDuplicados = false;
        for (int i = 0; i < numeros.Length - 1; i++)
            for (int j = i + 1; j < numeros.Length; j++)
                if (numeros[i] == numeros[j])
                {
                    Console.WriteLine($"  Duplicado encontrado: {numeros[i]} (índices {i} y {j})");
                    hayDuplicados = true;
                }

        if (!hayDuplicados)
            Console.WriteLine("No se encontraron duplicados.");
    }

