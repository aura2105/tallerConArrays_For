    // ── EJERCICIO 1 ──────────────────────────────────────────────────────────
    static void Ejercicio01()
    {
        Console.WriteLine("=== 1. Registro de Temperaturas ===\n");

        double[] temperaturas = { 18.5, 22.0, 19.0, 24.0, 26.5, 21.0, 20.0 };
        string[] dias = { "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo" };

        Console.WriteLine("Temperaturas originales:");
        for (int i = 0; i < temperaturas.Length; i++)
            Console.WriteLine($"  {dias[i]}: {temperaturas[i]}°C");

        // Modificar el tercer día (índice 2) a 25°C
        temperaturas[2] = 25.0;
        Console.WriteLine($"\nTemperatura del {dias[2]} actualizada a: {temperaturas[2]}°C");

        Console.WriteLine("\nTemperaturas actualizadas:");
        for (int i = 0; i < temperaturas.Length; i++)
            Console.WriteLine($"  {dias[i]}: {temperaturas[i]}°C");
    }

    // ── EJERCICIO 2 ──────────────────────────────────────────────────────────
    static void Ejercicio02()
    {
        Console.WriteLine("=== 2. Secuencia Fibonacci ===\n");

        int[] fibonacci = new int[10];
        fibonacci[0] = 0;
        fibonacci[1] = 1;

        for (int i = 2; i < fibonacci.Length; i++)
            fibonacci[i] = fibonacci[i - 1] + fibonacci[i - 2];

        Console.WriteLine("Secuencia Fibonacci (10 elementos):");
        for (int i = 0; i < fibonacci.Length; i++)
            Console.Write($"{fibonacci[i]}  ");
        Console.WriteLine();
    }

