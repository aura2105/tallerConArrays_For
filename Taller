    // ── EJERCICIO 4 ──────────────────────────────────────────────────────────
    static void Ejercicio04()
    {
        Console.WriteLine("=== 4. Promedio de Calificaciones ===\n");

        double[] calificaciones = { 3.5, 4.0, 2.8, 4.5, 3.9, 2.5, 4.8, 3.2 };
        double suma = 0;

        Console.WriteLine("Calificaciones:");
        foreach (double cal in calificaciones)
        {
            Console.Write($"  {cal}");
            suma += cal;
        }

        double promedio = suma / calificaciones.Length;
        Console.WriteLine($"\n\nSuma total: {suma}");
        Console.WriteLine($"Número de estudiantes: {calificaciones.Length}");
        Console.WriteLine($"Promedio: {promedio:F2}");
    }

    // ── EJERCICIO 5 ──────────────────────────────────────────────────────────
    static void Ejercicio05()
    {
        Console.WriteLine("=== 5. Buscador de Valores ===\n");

        int[] numeros = { 4, 15, 7, 23, 11, 42, 8, 19, 3, 30 };

        Console.Write("Arreglo: ");
        foreach (int n in numeros) Console.Write($"{n} ");
        Console.WriteLine();

        Console.Write("\nIngrese el número a buscar: ");
        if (int.TryParse(Console.ReadLine(), out int buscar))
        {
            bool encontrado = false;
            for (int i = 0; i < numeros.Length; i++)
            {
                if (numeros[i] == buscar)
                {
                    Console.WriteLine($"✔️ El número {buscar} fue encontrado en el índice {i}.");
                    encontrado = true;
                    break;
                }
            }
            if (!encontrado)
                Console.WriteLine($"✘ El número {buscar} no se encuentra en el arreglo.");
        }
        else
        {
            Console.WriteLine("Entrada no válida.");
        }
    }

