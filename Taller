    {
        Console.WriteLine("=== 19. Mapa de Coordenadas (2x2) ===\n");

        string[,] mapa = {
            { "Norte-Oeste", "Norte-Este" },
            { "Sur-Oeste",   "Sur-Este"   }
        };

        Console.WriteLine("Mapa actual:");
        for (int i = 0; i < 2; i++)
        {
            for (int j = 0; j < 2; j++)
