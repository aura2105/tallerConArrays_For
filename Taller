        }

        Console.Write("\nIngrese fila (0 o 1): ");
        int.TryParse(Console.ReadLine(), out int fila);
        Console.Write("Ingrese columna (0 o 1): ");
        int.TryParse(Console.ReadLine(), out int col);

        if (fila >= 0 && fila < 2 && col >= 0 && col < 2)
        {
            mapa[fila, col] = "Explorado";
            Console.WriteLine($"\nPosición [{fila},{col}] actualizada a 'Explorado'\n");
            Console.WriteLine("Mapa actualizado:");
            for (int i = 0; i < 2; i++)
            {
                for (int j = 0; j < 2; j++)
                    Console.Write($"[{mapa[i, j],12}] ");
                Console.WriteLine();
            }
        }
        else
        {
            Console.WriteLine("Coordenada no válida.");
        }
    }

    // ── EJERCICIO 20 ─────────────────────────────────────────────────────────
    static void Ejercicio20()
    {
        Console.WriteLine("=== 20. Análisis de Ventas Mensuales (2D & LINQ) ===\n");

        // Filas = meses (0-2), Columnas = categorías (0-3)
        double[,] ventas = {
            { 200.0, 150.0, 300.0, 120.0 },  // Mes 1
            { 180.0, 210.0, 275.0, 190.0 },  // Mes 2
            { 220.0, 175.0, 310.0, 160.0 }   // Mes 3
        };
        string[] categorias = { "Electrónica", "Ropa", "Alimentos", "Juguetes" };

        Console.WriteLine("Ventas por mes y categoría:");
        Console.Write($"{"",10}");
        foreach (string c in categorias) Console.Write($"{c,12}");
        Console.WriteLine();

        for (int i = 0; i < 3; i++)
        {
            Console.Write($"  Mes {i + 1}:  ");
            for (int j = 0; j < 4; j++)
                Console.Write($"${ventas[i, j],10}");
            Console.WriteLine();
        }

        // Total ventas mes 2 (índice 1) con bucle
        double totalMes2 = 0;
        for (int j = 0; j < 4; j++)
            totalMes2 += ventas[1, j];
        Console.WriteLine($"\nTotal ventas Mes 2 (bucle): ${totalMes2}");

        // Valor más alto con LINQ
        double[] todosLosValores = new double[3 * 4];
        int idx = 0;
        for (int i = 0; i < 3; i++)
            for (int j = 0; j < 4; j++)
                todosLosValores[idx++] = ventas[i, j];

        Console.WriteLine($"Valor más alto en toda la matriz (LINQ): ${todosLosValores.Max()}");
    }
